<UserControl x:Class="KaylesStepsRecorder.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="48,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Record a repro. Ship a report." Style="{StaticResource HeaderText}"/>
            <TextBlock Text="Capture every click with context. Edit. Export. Attach to your ticket."
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Primary CTA cards -->
        <Grid Grid.Row="1" Margin="0,36,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Background="{DynamicResource AccentGradientBrush}" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="&#x25CF; NEW RECORDING" FontSize="11" Foreground="White" Opacity="0.9" FontWeight="SemiBold"/>
                    <TextBlock Text="Start capturing" FontSize="22" FontWeight="SemiBold" Foreground="White" Margin="0,8,0,4"/>
                    <TextBlock Text="Global hooks pick up every click and keystroke." Foreground="White" Opacity="0.85" FontSize="12" TextWrapping="Wrap"/>
                    <Button Content="Start Recording" Margin="0,18,0,0" HorizontalAlignment="Left"
                            Background="White" Foreground="#FF4C5FDB" FontWeight="SemiBold" Padding="20,10"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding NewSessionCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="&#x270E; REVIEW" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="Edit your last capture" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <TextBlock Text="Rename steps, add notes, flag bugs, drop screenshots that leaked sensitive data." TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    <Button Content="Open review" Style="{StaticResource SecondaryButton}" Margin="0,18,0,0" HorizontalAlignment="Left"
                            Command="{Binding NavigateReviewCommand}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="&#x2B07; EXPORT" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="Ship a polished report" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <TextBlock Text="HTML, PDF-ready, or Markdown. Embed screenshots. Attach to Jira." TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    <Button Content="Open export" Style="{StaticResource SecondaryButton}" Margin="0,18,0,0" HorizontalAlignment="Left"
                            Command="{Binding NavigateExportCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tips -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,36,0,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="How it works" Style="{StaticResource SubheaderText}"/>
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22">
                    1. Click <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">Start Recording</Run> &#x2014; the app minimises and a floating toolbar appears.
                    <LineBreak/>
                    2. Perform the bug repro in the target app. Each click is captured with a screenshot of the correct window, not the desktop.
                    <LineBreak/>
                    3. Click <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">Stop</Run>. You are taken to the Review screen where you can clean up the steps, add notes, and flag Expected vs Actual.
                    <LineBreak/>
                    4. Hit <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">Export</Run> to produce a polished HTML / Markdown report ready to attach to your ticket.
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
