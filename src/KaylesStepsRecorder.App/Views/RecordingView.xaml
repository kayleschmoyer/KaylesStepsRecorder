<UserControl x:Class="KaylesStepsRecorder.App.Views.RecordingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:KaylesStepsRecorder.App.Converters">
    <UserControl.Resources>
        <conv:PathToImageSourceConverter x:Key="PathToImg"/>
        <conv:NullToVisibilityConverter x:Key="NotNullVis"/>
    </UserControl.Resources>

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with state badge -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Recording session" Style="{StaticResource HeaderText}"/>
                <TextBlock Text="{Binding StepCount, StringFormat='{}{0} step(s) captured'}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="20" Padding="14,6"
                    Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StateText}" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Control toolbar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,24,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="&#x25CF; Start Recording" Style="{StaticResource PrimaryButton}" Command="{Binding StartCommand}" Margin="0,0,12,0"/>
                <Button Content="&#x275A;&#x275A; Pause" Style="{StaticResource SecondaryButton}" Command="{Binding PauseCommand}" Margin="0,0,12,0"/>
                <Button Content="&#x25B6; Resume" Style="{StaticResource SecondaryButton}" Command="{Binding ResumeCommand}" Margin="0,0,12,0"/>
                <Button Content="&#x25A0; Stop &amp; Review" Style="{StaticResource PrimaryButton}" Command="{Binding StopCommand}" Margin="0,0,12,0"/>
                <Button Content="Cancel" Style="{StaticResource DangerButton}" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>

        <!-- Error banner -->
        <Border Grid.Row="1" Padding="16,12" CornerRadius="8"
                Background="{DynamicResource DangerBrush}" Margin="0,12,0,0" VerticalAlignment="Top"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White"/>
        </Border>

        <!-- Live step list -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,24,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="LIVE STEPS" Style="{StaticResource MutedText}" Margin="0,0,0,12"/>
                <TextBlock DockPanel.Dock="Top"
                           Text="Steps will appear here as you click. Nothing is being recorded yet."
                           Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" Margin="0,0,0,8">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Steps.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ListBox ItemsSource="{Binding Steps}" HorizontalContentAlignment="Stretch"
                         ScrollViewer.CanContentScroll="False">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Width="36" Height="36" CornerRadius="18" Margin="0,0,14,0">
                                        <TextBlock Text="{Binding StepNumber}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImg}}" Stretch="UniformToFill" Height="64"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding TimestampText}" Style="{StaticResource MutedText}"/>
                                            <TextBlock Text=" &#x2022; " Style="{StaticResource MutedText}"/>
                                            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
