<UserControl x:Class="KaylesStepsRecorder.App.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:KaylesStepsRecorder.App.Converters">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Export" Style="{StaticResource HeaderText}"/>
            <TextBlock Text="Choose a format, pick a destination, and ship the report." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,24,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Format" Style="{StaticResource SubheaderText}"/>
                    <ComboBox x:Name="FormatCombo" Margin="0,0,0,12" SelectionChanged="FormatCombo_SelectionChanged">
                        <ComboBoxItem Content="HTML - Full report (recommended)" IsSelected="True"/>
                        <ComboBoxItem Content="HTML - Compact"/>
                        <ComboBoxItem Content="Markdown"/>
                    </ComboBox>

                    <TextBlock Text="Output path" Style="{StaticResource SubheaderText}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse..." Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" Padding="14,8" Click="BrowseClick"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock Text="Options" Style="{StaticResource SubheaderText}"/>
                    <CheckBox Content="Include screenshots" IsChecked="{Binding IncludeScreenshots}" Margin="0,0,0,6"/>
                    <CheckBox Content="Embed images inline (self-contained file)" IsChecked="{Binding EmbedImagesAsBase64}" Margin="0,0,0,6"/>
                    <CheckBox Content="Include timestamps" IsChecked="{Binding IncludeTimestamps}" Margin="0,0,0,6"/>
                    <CheckBox Content="Include click coordinates" IsChecked="{Binding IncludeCoordinates}" Margin="0,0,0,6"/>
                    <CheckBox Content="Include notes" IsChecked="{Binding IncludeNotes}" Margin="0,0,0,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,24,0,0">
            <Button Content="Export now" Style="{StaticResource PrimaryButton}" Command="{Binding ExportCommand}" Padding="28,12"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
